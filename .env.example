# WitsV3 secrets template — copy to .env and fill in your values.
# .env is gitignored; never commit real secrets.

# Supabase (optional — only needed for the Supabase memory backend / sync)
WITSV3_SUPABASE_URL=
WITSV3_SUPABASE_KEY=

# SHA256 hash of the admin auth token. Generate with: python setup_auth.py
WITSV3_AUTH_TOKEN_HASH=

# Access token for the web UI (any strong random string). Required when
# web_ui.require_auth is true; enter it once in the browser when prompted.
WITSV3_WEB_TOKEN=

# Your name in web UI access logs (owner sessions). Guests show their /join name (e.g. Sean).
WITSV3_OWNER_NAME=

# Guest / family-tester access (optional). Enable web_ui.guest_access.enabled
# in config.yaml, then set a short invite code guests type on /join.
# WITSV3_GUEST_SECRET signs guest session tokens (recommended random string);
# if unset, a key is derived from WEB_TOKEN + INVITE.
# Owner admin: /settings → Family testers (age band, revoke, merge).
# Content blocklists: config/guest_policy.yaml
WITSV3_GUEST_INVITE=
WITSV3_GUEST_SECRET=

# Web search API keys (optional — improves search quality; DuckDuckGo is the keyless fallback)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Anthropic API key (optional — only needed for the "ask Claude" escalation
# feature; each escalation is a per-request approval in the web UI, never automatic)
ANTHROPIC_API_KEY=
