# WitsV3 secrets template — copy to .env and fill in your values.
# .env is gitignored; never commit real secrets.

# Supabase (optional — only needed for the Supabase memory backend / sync)
WITSV3_SUPABASE_URL=
WITSV3_SUPABASE_KEY=

# SHA256 hash of the admin auth token. Generate with: python setup_auth.py
WITSV3_AUTH_TOKEN_HASH=

# Access token for the web UI (any strong random string). Required when
# web_ui.require_auth is true; enter it once in the browser when prompted.
WITSV3_WEB_TOKEN=
